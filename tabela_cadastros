<!doctype html>

<html lang="pt-BR">

<head>

    <meta charset="UTF-8" />

    <title>Cadastro de escolas</title>

    <style>

        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            padding: 30px;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 0 10px #ccc;
        }

        h1 {
            text-align: center;
            color: #2c3e50;
        }

        form {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        input {
            padding: 10px;
            border: 1px solid #bbb;
            border-radius: 5px;
        }

        button {
            width: 180px;
            padding: 12px;
            background-color: #2a4d69;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            grid-column: 1;
            justify-self: start;
        }

        button:hover {
            background-color: #1f3a50;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            background-color: #2a4d69;
            color: white;
            padding: 10px;
        }

        td {
            padding: 8px;
            border: 1px solid #ddd;
            text-align: center;
        }

        tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        .editar {
            color: #2980b9;
            cursor: pointer;
            font-weight: bold;
        }

        .excluir {
            color: #c0392b;
            cursor: pointer;
            font-weight: bold;
        }

    </style>
</head>

<body>
    <header>
        <header>
     
